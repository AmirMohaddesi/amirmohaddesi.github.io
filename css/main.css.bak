/**
 * =================================================================== 
 *
 *  Kards v1.0 Main Stylesheet
 *  url: styleshout.com
 *  03-01-2016
 *  ------------------------------------------------------------------
 *  Customized for Amirhosein Mohaddesi portfolio
 *
 * =================================================================== 
 */

 @import url("fonts.css");
 @import url("font-awesome/css/font-awesome.min.css");
 @import url("micons/micons.css");
 
 :root {
   --bg-dark: #0b1020;
   --bg-dark-soft: #111827;
   --bg-light: #f8fafc;
   --surface-light: #ffffff;
   --text-dark: #0f172a;
   --text-muted-light: #475569;
   --text-bright: #f8fafc;
   --text-muted-dark: #cbd5e1;
   --accent: #ec4899;
   --accent-hover: #db2777;
   --border-soft: rgba(255, 255, 255, 0.08);
   --shadow-soft: 0 10px 30px rgba(2, 8, 23, 0.08);
 }
 
 html {
   font-size: 10px;
 }
 
 @media only screen and (max-width:1024px) {
   html { font-size: 9.411764705882353px; }
 }
 @media only screen and (max-width:768px) {
   html { font-size: 10px; }
 }
 @media only screen and (max-width:400px) {
   html { font-size: 9.411764705882353px; }
 }
 
 html, body {
   height: 100%;
 }
 
 body {
   background: var(--bg-dark);
   font-family: "lora-regular", serif;
   font-size: 1.7rem;
   line-height: 3rem;
   color: var(--text-muted-dark);
   text-align: left;
 }
 
 a, a:visited {
   color: var(--text-dark);
   -moz-transition: all 0.3s ease-in-out;
   -o-transition: all 0.3s ease-in-out;
   -webkit-transition: all 0.3s ease-in-out;
   -ms-transition: all 0.3s ease-in-out;
   transition: all 0.3s ease-in-out;
 }
 a:hover, a:focus, a:active {
   color: var(--accent);
   outline: 0;
 }
 
 h1, h2, h3, h4, h5, h6, .h01, .h02, .h03, .h04, .h05, .h06 {
   font-family: "poppins-semibold", sans-serif;
   color: var(--text-dark);
   font-style: normal;
   text-rendering: optimizeLegibility;
   margin-bottom: 2.1rem;
 }
 h3, .h03, h4, .h04 {
   margin-bottom: 1.8rem;
 }
 h5, .h05, h6, .h06 {
   font-family: "poppins-bold";
   margin-bottom: 1.2rem;
 }
 h1, .h01 {
   font-size: 3.1rem;
   line-height: 1.355;
   letter-spacing: -.1rem;
 }
 @media only screen and (max-width:600px) {
   h1, .h01 {
	 font-size: 2.6rem;
	 letter-spacing: -.07rem;
   }
 }
 h2, .h02 {
   font-size: 2.4rem;
   line-height: 1.25;
 }
 h3, .h03 {
   font-size: 2rem;
   line-height: 1.5;
 }
 h4, .h04 {
   font-size: 1.7rem;
   line-height: 1.765;
 }
 h5, .h05 {
   font-size: 1.4rem;
   line-height: 1.714;
   text-transform: uppercase;
   letter-spacing: .15rem;
 }
 h6, .h06 {
   font-size: 1.3rem;
   line-height: 1.846;
   text-transform: uppercase;
   letter-spacing: .15rem;
 }
 
 p img {
   margin: 0;
 }
 
 p.lead {
   font-family: "lora-regular", serif;
   font-size: 2rem;
   line-height: 1.8;
   color: var(--text-muted-light);
 }
 @media only screen and (max-width:768px) {
   p.lead {
	 font-size: 1.7rem;
   }
 }
 
 em, i, strong, b {
   font-size: 1.7rem;
   line-height: 3rem;
   font-style: normal;
   font-weight: normal;
 }
 em, i { font-family: "lora-italic", serif; }
 strong, b { font-family: "lora-bold", serif; }
 
 small {
   font-size: 1.2rem;
   line-height: inherit;
 }
 
 button, .button {
   margin-bottom: 1.2rem;
 }
 
 input,
 textarea,
 select,
 pre,
 blockquote,
 figure,
 table,
 p,
 ul,
 ol,
 dl,
 form,
 .fluid-video-wrapper,
 .ss-custom-select {
   margin-bottom: 3rem;
 }
 
 .bgrid {
   padding: 0 20px;
 }
 @media only screen and (max-width:1024px) {
   .bgrid { padding: 0 18px; }
 }
 @media only screen and (max-width:768px) {
   .bgrid { padding: 0 15px; }
 }
 @media only screen and (max-width:600px) {
   .bgrid { padding: 0 10px; }
 }
 @media only screen and (max-width:400px) {
   .bgrid { padding: 0; }
 }
 
 .pace {
   -webkit-pointer-events: none;
   pointer-events: none;
   -webkit-user-select: none;
   -moz-user-select: none;
   user-select: none;
 }
 .pace-inactive {
   display: none;
 }
 .pace .pace-progress {
   background: var(--accent);
   position: fixed;
   z-index: 900;
   top: 0;
   right: 100%;
   width: 100%;
   height: 6px;
 }
 
 #preloader {
   position: fixed;
   inset: 0;
   background: var(--bg-dark);
   z-index: 800;
   height: 100%;
   width: 100%;
 }
 .no-js #preloader, .oldie #preloader {
   display: none;
 }
 #loader {
   position: absolute;
   left: 50%;
   top: 50%;
   width: 60px;
   height: 60px;
   margin: -30px 0 0 -30px;
   padding: 0;
 }
 #loader:before {
   content: "";
   border-top: 11px solid rgba(255, 255, 255, 0.1);
   border-right: 11px solid rgba(255, 255, 255, 0.1);
   border-bottom: 11px solid rgba(255, 255, 255, 0.1);
   border-left: 11px solid var(--accent);
   -webkit-animation: load 1.1s infinite linear;
   animation: load 1.1s infinite linear;
   display: block;
   border-radius: 50%;
   width: 60px;
   height: 60px;
 }
 @-webkit-keyframes load {
   0% { -webkit-transform: rotate(0deg); transform: rotate(0deg); }
   100% { -webkit-transform: rotate(360deg); transform: rotate(360deg); }
 }
 @keyframes load {
   0% { -webkit-transform: rotate(0deg); transform: rotate(0deg); }
   100% { -webkit-transform: rotate(360deg); transform: rotate(360deg); }
 }
 
 /* Buttons */
 .button,
 a.button,
 button,
 input[type="submit"],
 input[type="reset"],
 input[type="button"] {
   display: inline-block;
   font-family: "poppins-bold", sans-serif;
   font-size: 1.4rem;
   text-transform: uppercase;
   letter-spacing: .24rem;
   height: 5.4rem;
   line-height: 5.4rem;
   padding: 0 3rem;
   margin: 0 .3rem 1.2rem 0;
   background: #d8d8d8;
   color: var(--text-dark);
   text-decoration: none;
   cursor: pointer;
   text-align: center;
   white-space: nowrap;
   border: none;
   border-radius: 10px;
   transition: all 0.3s ease-in-out;
 }
 .button:hover,
 a.button:hover,
 button:hover,
 input[type="submit"]:hover,
 input[type="reset"]:hover,
 input[type="button"]:hover,
 .button:focus,
 button:focus,
 input[type="submit"]:focus,
 input[type="reset"]:focus,
 input[type="button"]:focus {
   background: #bebebe;
   color: #000000;
   outline: 0;
 }
 .button.button-primary,
 a.button.button-primary,
 button.button-primary,
 input[type="submit"].button-primary,
 input[type="reset"].button-primary,
 input[type="button"].button-primary {
   background: var(--accent);
   color: #FFFFFF;
 }
 .button.button-primary:hover,
 a.button.button-primary:hover,
 button.button-primary:hover,
 input[type="submit"].button-primary:hover,
 input[type="reset"].button-primary:hover,
 input[type="button"].button-primary:hover,
 .button.button-primary:focus,
 button.button-primary:focus,
 input[type="submit"].button-primary:focus,
 input[type="reset"].button-primary:focus,
 input[type="button"].button-primary:focus {
   background: var(--accent-hover);
 }
 button.full-width, .button.full-width {
   width: 100%;
   margin-right: 0;
 }
 button.stroke, .button.stroke {
   background: transparent !important;
   border: 2px solid rgba(255,255,255,0.45);
   color: var(--text-bright);
   line-height: 5rem;
 }
 button.stroke:hover, .button.stroke:hover {
   border-color: var(--accent);
   color: var(--accent);
 }
 
 /* Sections */
 .section-intro {
   max-width: 900px;
   margin: 0 auto 4.8rem auto;
   text-align: center;
 }
 .section-intro h5 {
   color: var(--accent);
 }
 .section-intro h1 {
   margin-bottom: 1.8rem;
 }
 .grey-section {
   background: var(--bg-dark);
 }
 
 /* Intro */
 #intro {
   width: 100%;
   height: 100%;
   min-height: 720px;
   background: linear-gradient(rgba(4, 8, 20, 0.72), rgba(4, 8, 20, 0.78)), var(--bg-dark);
   display: table;
   position: relative;
   text-align: center;
 }
 #intro .intro-overlay {
   position: absolute;
   inset: 0;
   background: transparent;
 }
 #intro .intro-content {
   display: table-cell;
   vertical-align: middle;
   text-align: center;
   transform: translateY(-2rem);
 }
 #intro .intro-content h5 {
   color: var(--accent);
   font-size: 2rem;
   letter-spacing: .3rem;
 }
 #intro .intro-content h1 {
   color: var(--text-bright);
   font-size: 8.4rem;
   line-height: 1.08;
   margin-bottom: 2.4rem;
 }
 #intro .intro-position {
   font-family: "poppins-regular", sans-serif;
   font-size: 1.7rem;
   line-height: 3rem;
   margin-bottom: 4rem;
 }
 #intro .intro-position span {
   color: var(--text-muted-dark);
   display: inline-block;
   margin: 0 .5rem;
 }
 .intro-social {
   display: block;
   position: absolute;
   width: 100%;
   left: 0;
   bottom: 6rem;
   font-size: 3.2rem;
   margin: 0;
   padding: 0;
 }
 .intro-social li {
   display: inline-block;
   margin: 0 1rem;
   padding: 0;
 }
 .intro-social li a,
 .intro-social li a:visited {
   color: rgba(255,255,255,0.88);
 }
 .intro-social li a:hover,
 .intro-social li a:focus {
   color: var(--accent);
 }
 
 /* About */
 #about {
   background: var(--bg-light);
   padding-top: 12rem;
   padding-bottom: 15rem;
 }
 #about .section-intro {
   margin-bottom: 3rem;
 }
 #about .section-intro h1,
 #about h3,
 #about .info-list li strong {
   color: var(--text-dark);
 }
 #about .section-intro h5 {
   color: var(--accent);
 }
 .intro-info {
   margin-top: 4.2rem;
   margin-right: -30px;
   margin-left: -30px;
 }
 .intro-info::after {
   content: "";
   display: table;
   clear: both;
 }
 .intro-info img {
   height: 20rem;
   width: 20rem;
   border-radius: 50%;
   margin: 1rem 2rem 0 0;
   float: left;
   box-shadow: var(--shadow-soft);
 }
 .intro-info .lead {
   padding-left: 22rem;
   text-align: left;
   color: var(--text-muted-light);
 }
 .about-content {
   position: relative;
   text-align: left;
   max-width: 950px;
   margin-bottom: 3.6rem;
 }
 .about-content h3 {
   font-family: "poppins-bold", sans-serif;
   font-size: 1.8rem;
   text-transform: uppercase;
   letter-spacing: .25rem;
 }
 .about-content .info-list {
   list-style: none;
   margin-left: 0;
 }
 .about-content .info-list li {
   padding: 0 0 1.5rem 0;
   margin-bottom: .6rem;
 }
 .about-content .info-list li strong {
   font-family: "poppins-bold", sans-serif;
   text-transform: uppercase;
   letter-spacing: .2rem;
   font-size: 1.5rem;
   line-height: 3rem;
 }
 .about-content .info-list li span {
   display: block;
   font-family: "poppins-regular", sans-serif;
   color: var(--text-muted-light);
   font-size: 1.5rem;
   line-height: 1.6;
   overflow-wrap: break-word;
 }
 .about-content .skill-bars {
   margin-top: 4rem;
 }
 
 /* Skill bars */
 .skill-bars {
   list-style: none;
   margin: 0;
 }
 .skill-bars li {
   height: auto;
   background: transparent;
   margin-bottom: 2.8rem;
   padding: 0;
   position: relative;
 }
 .skill-bars li strong {
   display: block;
   font-family: "poppins-semibold", sans-serif;
   color: var(--text-dark);
   margin-top: 1rem;
   font-size: 2rem;
 }
 .skill-bars li .progress {
   background: #e5e7eb;
   position: relative;
   height: 1.2rem;
   border-radius: 999px;
   overflow: hidden;
   box-shadow: inset 0 1px 3px rgba(15,23,42,0.08);
 }
 .skill-bars li .progress span {
   position: absolute;
   right: 0;
   top: -3.2rem;
   display: block;
   color: var(--text-muted-light);
   font-size: 1.4rem;
 }
 .skill-bars li .progress::after {
   content: "";
   position: absolute;
   inset: 0 auto 0 0;
   background: linear-gradient(90deg, var(--accent), #8b5cf6);
   border-radius: 999px;
 }
 .skill-bars li .percent95::after { width: 95%; }
 .skill-bars li .percent90::after { width: 90%; }
 .skill-bars li .percent85::after { width: 85%; }
 .skill-bars li .percent80::after { width: 80%; }
 
 .button-section {
   text-align: center;
 }
 .button-section .button {
   width: 250px;
 }
 .button-section [class*="col-"] .button:first-child {
   margin-right: 4rem;
 }
 
 /* Resume */
 #resume {
   background: var(--bg-dark);
   padding-top: 12rem;
   padding-bottom: 12rem;
 }
 #resume .section-intro h1,
 #resume .resume-header h2,
 #resume .timeline-header h3,
 #resume .timeline-header h4,
 #resume .timeline-content h4,
 #resume .timeline-content h4 a {
   color: var(--text-bright);
 }
 #resume .resume-header h2 {
   color: var(--accent);
   font-size: 4rem;
   margin-bottom: 4rem;
 }
 #resume .section-intro h1 {
   color: rgba(248,250,252,0.18);
 }
 .resume-timeline {
   max-width: 980px;
   margin-top: 5rem;
 }
 .timeline-wrap {
   position: relative;
   margin-top: 1.5rem;
 }
 .timeline-wrap::before {
   content: "";
   display: block;
   width: 2px;
   background: rgba(255,255,255,0.08);
   position: absolute;
   left: 2rem;
   top: 0;
   bottom: 0;
 }
 .timeline-block {
   position: relative;
   padding-left: 7rem;
   margin-bottom: 4rem;
 }
 .timeline-ico {
   height: 4rem;
   width: 4rem;
   line-height: 4rem;
   background: var(--accent);
   border-radius: 50%;
   text-align: center;
   color: #fff;
   position: absolute;
   left: 0;
   top: 0;
   box-shadow: 0 0 0 8px rgba(236,72,153,0.14);
 }
 .timeline-header h3,
 .timeline-header h4 {
   margin-bottom: .8rem;
 }
 .timeline-header p,
 .timeline-content p {
   color: var(--text-muted-dark);
   line-height: 1.8;
 }
 .timeline-content {
   background: rgba(255,255,255,0.03);
   border: 1px solid rgba(255,255,255,0.06);
   border-radius: 16px;
   padding: 2.2rem 2.4rem;
   box-shadow: 0 8px 30px rgba(2,8,23,0.16);
 }
 .timeline-content h4 {
   color: var(--text-bright);
 }
 .timeline-content a,
 .timeline-content a:visited {
   color: #f9a8d4;
 }
 .timeline-content a:hover,
 .timeline-content a:focus {
   color: var(--accent);
 }
 
 /* Contact */
 #contact {
   background: var(--bg-dark);
   padding-top: 10rem;
   padding-bottom: 8rem;
 }
 #contact .section-intro h5,
 #contact .contact-info .icon i {
   color: var(--accent);
 }
 #contact .contact-info {
   max-width: 1000px;
   margin: 0 auto;
   text-align: center;
 }
 #contact .contact-info h5 {
   color: rgba(248,250,252,0.28);
   letter-spacing: .18rem;
 }
 #contact .contact-info p,
 #contact .contact-info a {
   color: var(--text-muted-dark);
 }
 #contact .contact-info a:hover,
 #contact .contact-info a:focus {
   color: var(--accent);
 }
 
 /* Footer */
 footer {
   background: var(--bg-dark-soft);
   padding: 3rem 0;
 }
 .footer-social {
   list-style: none;
   margin: 0;
   padding: 0;
 }
 .footer-social li {
   display: inline-block;
   margin-right: 1.4rem;
 }
 .footer-social li a,
 .footer-social li a:visited {
   color: rgba(255,255,255,0.78);
   font-size: 2rem;
 }
 .footer-social li a:hover,
 .footer-social li a:focus {
   color: var(--accent);
 }
 #go-top a,
 #go-top a:visited {
   color: rgba(255,255,255,0.78);
 }
 #go-top a:hover,
 #go-top a:focus {
   color: var(--accent);
 }
 
 .hf-embed {
   width: 100%;
   height: 900px;
   border: 0;
   border-radius: 14px;
   box-shadow: 0 8px 24px rgba(0,0,0,0.18);
 }
 
 @media (max-width: 1024px) {
   .intro-info {
	 margin-right: -40px;
	 margin-left: 0;
   }
   #intro .intro-content h1 {
	 font-size: 7rem;
   }
 }
 
 @media only screen and (max-width:768px) {
   .intro-info {
	 margin-right: 0;
	 margin-left: 0;
   }
   .intro-info img {
	 height: 9.6rem;
	 width: 9.6rem;
	 float: none;
	 display: block;
	 margin: 0 auto 1.6rem auto;
   }
   .intro-info .lead {
	 padding-left: 0;
	 padding-right: 0;
	 margin: 0 auto;
	 max-width: 92%;
	 text-align: left;
	 line-height: 1.8;
   }
   .about-content h3 {
	 text-align: center;
   }
   .about-content .info-list,
   .about-content .skill-bars {
	 margin-bottom: 4.2rem;
   }
   .button-section .button {
	 width: 100%;
	 margin-bottom: 2rem;
   }
   .button-section [class*="col-"] .button:first-child {
	 margin-right: 0;
   }
   .timeline-wrap::before {
	 display: none;
   }
   .timeline-block {
	 padding-left: 0;
	 margin-bottom: 3rem;
   }
   .timeline-ico {
	 display: none;
   }
   .timeline-content {
	 padding: 1.8rem;
   }
   .hf-embed {
	 height: 1100px;
   }
 }
 
 @media only screen and (max-width:600px) {
   .intro-info {
	 text-align: center;
	 margin-top: 3rem;
	 margin-left: 0;
	 margin-right: 0;
   }
   .intro-info img {
	 height: 8.5rem;
	 width: 8.5rem;
	 float: none;
	 display: block;
	 margin: 0 auto 1.8rem auto;
   }
   .intro-info .lead {
	 padding-left: 0;
	 padding-right: 0;
	 margin: 0 auto;
	 max-width: 92%;
	 text-align: left;
	 font-size: 1.7rem;
	 line-height: 1.8;
   }
   #intro .intro-content h1 {
	 font-size: 5.2rem;
   }
 }
 
 @media only screen and (max-width:480px) {
   .intro-info .lead {
	 max-width: 94%;
	 font-size: 1.65rem;
	 line-height: 1.75;
   }
   #intro .intro-content h1 {
	 font-size: 4.1rem;
   }
 }
 